# OpenAI API Key (required for intent detection and query planning)
OPENAI_API_KEY=your_openai_api_key_here

# Web demo mode (Streamlit Cloud / portfolio iframe)
# When true: Step 3 answer generation uses OpenAI instead of local Ollama.
# Production deployments should keep this false and use OLLAMA_ENABLED=true.
WEB_DEMO_MODE=false
WEB_DEMO_OPENAI_MODEL=gpt-4o-mini
WEB_DEMO_OPENAI_TEMPERATURE=0.25
WEB_DEMO_OPENAI_MAX_TOKENS=1200

# Optional: Local LLM settings (transformers)
LOCAL_LLM_ENABLED=false
LOCAL_LLM_MODEL=gpt2

# Ollama (recommended for local RAG answer generation)
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
# Faster: qwen2.5:3b (default). Better quality: qwen2.5:7b → ollama pull qwen2.5:7b
OLLAMA_MODEL=qwen2.5:3b
# Max tokens to generate; lower = faster (default 1024)
OLLAMA_NUM_PREDICT=1024
# Temperature: lower = more grounded, less hallucination (default 0.25). 0.7 = more varied
OLLAMA_TEMPERATURE=0.25
# GPU: Ollama uses GPU automatically if available. Check with: nvidia-smi
